# Copy this file to .env for local `vercel dev` testing, or add these directly
# in Vercel → Project → Settings → Environment Variables for deployment.
# Never commit real values.

# Google Cloud service account (Sheets access + Calendar freebusy reads)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=work.krishlalwani@gmail.com
GOOGLE_SHEET_ID=

# OAuth for the real work.krishlalwani@gmail.com account — required for
# creating booking events with attendees and sending the booking-notification
# email, since service accounts can't do either without Workspace Domain-Wide
# Delegation. Token must be authorized with scopes:
#   https://www.googleapis.com/auth/calendar.events
#   https://www.googleapis.com/auth/gmail.send
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Used to build the Razorpay payment link's callback_url
SITE_URL=https://kore360.com
